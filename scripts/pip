#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
VENV_PIP="$ROOT_DIR/.venv/bin/pip"

if [ ! -x "$VENV_PIP" ]; then
  echo "Missing project pip: $VENV_PIP" >&2
  echo "Bootstrap the repo environment first:" >&2
  echo "  cd $ROOT_DIR && make bootstrap-python" >&2
  exit 1
fi

exec "$VENV_PIP" "$@"
