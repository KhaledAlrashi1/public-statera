#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
VENV_FLASK="$ROOT_DIR/.venv/bin/flask"

if [ ! -x "$VENV_FLASK" ]; then
  echo "Missing project flask CLI: $VENV_FLASK" >&2
  echo "Bootstrap the repo environment first:" >&2
  echo "  cd $ROOT_DIR && make bootstrap-python" >&2
  exit 1
fi

exec "$VENV_FLASK" "$@"
