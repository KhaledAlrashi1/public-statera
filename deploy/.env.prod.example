# deploy/.env.prod.example — production environment reference
#
# Copy to .env.prod on the server, fill in every value marked [REQUIRED], then:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Format: KEY=value (no quotes needed for values without spaces)
# Secrets management: see Module 8c (sops + age). Until 8c ships, manage this
# file manually and keep it out of git (it is listed in .gitignore).
#
# Groups:
#   §A  Docker / image registry
#   §B  MySQL database
#   §C  Application secrets
#   §D  OAuth / OIDC
#   §E  Email (Postmark)
#   §F  Error tracking (Sentry)
#   §G  Feature flags
#   §H  Infrastructure (ports, paths)
#   §I  Analytics / background job tuning

# ── §A: Docker / image registry ───────────────────────────────────────────────

# [REQUIRED] Git SHA of the image to deploy. Set automatically by the CI deploy
# script (8d) from $GITHUB_SHA. Override manually for rollbacks.
# Example: GIT_SHA=a3f2c1d
GIT_SHA=

# [OPTIONAL] Image registry prefix. Default points to GHCR for this repo.
# Change only if hosting images in a private registry.
REGISTRY=ghcr.io/khaledalrashi1

# ── §B: MySQL database ────────────────────────────────────────────────────────

# [REQUIRED] MySQL root password. Used only during container first-run init.
# Generate: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=

# [REQUIRED] Database name.
# Example: MYSQL_DATABASE=statera_prod
MYSQL_DATABASE=statera_prod

# [REQUIRED] Application database user (non-root).
# Example: MYSQL_USER=statera
MYSQL_USER=statera

# [REQUIRED] Application database password.
# Generate: openssl rand -base64 32
MYSQL_PASSWORD=

# [REQUIRED] Hetzner Volume mount point for MySQL data directory.
# The volume must be formatted (ext4) and chown'd to 999:999 before starting MySQL.
# Set during bootstrap.sh §3. Do not change once MySQL has initialised.
# Example: MYSQL_DATA_PATH=/mnt/mysql-data
MYSQL_DATA_PATH=/mnt/mysql-data

# ── §C: Application secrets ───────────────────────────────────────────────────

# [REQUIRED] AES-256-GCM field encryption key for sensitive columns (e.g. account tokens).
# Must be a 64-character hex string (32 bytes).
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# [OPTIONAL] Previous encryption key — used during key rotation to decrypt
# values encrypted with the old key. Leave blank if no rotation is in progress.
# Format: 64-character hex string (same as ENCRYPTION_KEY).
ENCRYPTION_KEY_PREVIOUS=

# [REQUIRED] Session cookie signing secret for HS256 JWTs.
# Generate: openssl rand -base64 48
SESSION_SECRET=

# ── §D: OAuth / OIDC ──────────────────────────────────────────────────────────

# [REQUIRED] OAuth client ID from your Google Cloud Console application.
OAUTH_CLIENT_ID=

# [REQUIRED] OAuth client secret from your Google Cloud Console application.
OAUTH_CLIENT_SECRET=

# [OPTIONAL] OAuth issuer URL. Defaults to Google. Change for other OIDC providers.
# Default: https://accounts.google.com
OAUTH_ISSUER_URL=https://accounts.google.com

# [OPTIONAL] OAuth provider identifier. Currently only "google" is tested.
# Default: google
OAUTH_PROVIDER=google

# [REQUIRED] OAuth redirect URI — must match exactly what's registered in Google
# Cloud Console. Include the full path with scheme.
# Example: OAUTH_REDIRECT_URI=https://statera.example.com/api/auth/callback
OAUTH_REDIRECT_URI=

# [REQUIRED] Allowed CORS origins. Comma-separated list. Must include the
# production frontend origin. Do not include a trailing slash.
# Example: CORS_ORIGINS=https://statera.example.com
CORS_ORIGINS=

# ── §E: Email (Postmark) ──────────────────────────────────────────────────────

# [REQUIRED] Postmark server API token. Found in Postmark dashboard → API Tokens.
# Used for transactional emails (budget alerts, goal milestones).
POSTMARK_API_KEY=

# [REQUIRED] From address for outgoing email. Must be a verified Sender Signature
# in Postmark (domain or single address verification).
# Example: MAIL_FROM_ADDRESS=noreply@statera.example.com
MAIL_FROM_ADDRESS=

# ── §F: Error tracking (Sentry) ───────────────────────────────────────────────

# [REQUIRED] Sentry DSN. Found in Sentry project → Settings → Client Keys.
# Leave blank to disable Sentry (errors are still logged to stdout).
SENTRY_DSN=

# [OPTIONAL] Sentry environment tag. Appears in Sentry issue grouping.
# Default: production
SENTRY_ENVIRONMENT=production

# Note: SENTRY_RELEASE is derived from GIT_SHA in docker-compose.prod.yml.
# Do not set it here — it will be overridden.

# ── §G: Feature flags ─────────────────────────────────────────────────────────

# [OPTIONAL] Enable Open Banking / bank sync routes.
# Deferred indefinitely (CBK dependency). Keep false.
# Default: false
ENABLE_OPEN_BANKING=false

# [OPTIONAL] Enable transaction template suggestions.
# Feature-flagged off in Flask; not ported. Keep false.
# Default: false
ENABLE_TEMPLATE_SUGGESTIONS=false

# [OPTIONAL] Enable recurring-pattern detection (R12 analytics route).
# Set to false to return an empty patterns list without computation.
# Default: true
ENABLE_RECURRING_PATTERNS=true

# ── §H: Infrastructure (ports, paths) ────────────────────────────────────────

# [OPTIONAL] HTTP port exposed by nginx on the host. Caddy (8e) will replace
# nginx and bind to 80/443 directly. Until then nginx handles TLS termination.
# Default: 80
NGINX_HTTP_PORT=80

# [OPTIONAL] HTTPS port exposed by nginx on the host.
# Default: 443
NGINX_HTTPS_PORT=443

# Note: API_PORT is set to "3000" in docker-compose.prod.yml and should not
# be exposed to the host. The API container is reachable only via nginx/Caddy.

# ── §I: Analytics / background job tuning ────────────────────────────────────

# [OPTIONAL] Days of login recency for snapshot rebuild eligibility.
# Only users active within this window get their dashboard rebuilt each cycle.
# Default: 14
SNAPSHOT_REBUILD_WINDOW_DAYS=14

# [OPTIONAL] Per-user concurrency for snapshot rebuild BullMQ job.
# Default: 5
SNAPSHOT_REBUILD_CONCURRENCY=5

# [OPTIONAL] Activation report generation interval (hours between runs).
# Default: 24
ACTIVATION_REPORT_INTERVAL_HOURS=24

# [OPTIONAL] Activation report retention (days of historical reports to keep).
# Default: 90
ACTIVATION_REPORT_INTERVAL_DAYS=90

# [OPTIONAL] Filesystem path where activation reports are written.
# The path must be writable by the worker container.
# Default: /tmp/activation-reports
ACTIVATION_REPORT_PATH=/tmp/activation-reports

# [OPTIONAL] Max failures before 2FA pending session is invalidated.
# Default: 3
PENDING_2FA_MAX_FAILURES=3
