{
	email ops@staterafinance.app
}

staterafinance.app {
	# Body size limit — applies to API uploads via
	# reverse_proxy. Static file routes don't read bodies,
	# so this is a no-op there.
	# Matches nginx client_max_body_size 25m.
	request_body {
		max_size 25MB
	}

	# Security headers on all responses.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# ENFORCING as of 2026-07-10 (was Report-Only since 2026-05-24; see
		# TODO(module-8e-csp-enforcement) close-out in CLAUDE.md). Report-Only
		# never collected — the policy carried no report-uri/report-to, so the
		# "observation window" was vacuous; evidence was a console-verified
		# operator page-walk instead. style-src/font-src carry the Google Fonts
		# hosts (index.html <link>); self-host + narrow-back-to-'self' is deferred
		# to the UX-redesign theme work. Standing rule: any NEW external resource
		# must be added here in the same commit that introduces it, or prod blocks it.
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self'; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
	}

	# API routes — proxy to Hono. X-Real-IP is set explicitly;
	# Caddy passes X-Forwarded-Proto and X-Forwarded-For automatically.
	handle /api/* {
		reverse_proxy api:3000 {
			header_up X-Real-IP {remote_host}
		}
	}

	# Health and readiness probes — root-level, not under /api/.
	@probes path /healthz /readyz
	handle @probes {
		reverse_proxy api:3000 {
			header_up X-Real-IP {remote_host}
		}
	}

	# Immutable assets — 1-year cache. Matches nginx "expires 1y; Cache-Control public, immutable".
	handle /assets/* {
		root * /srv
		header Cache-Control "public, immutable, max-age=31536000"
		file_server
	}

	# SPA fallback — all other paths serve index.html.
	handle {
		root * /srv
		try_files {path} {path}/ /index.html
		file_server
	}
}
