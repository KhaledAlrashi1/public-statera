# Local environment and secrets — never commit plaintext
.env
.env.prod
.env.prod.filled       # temporary file used when creating the encrypted secrets file
secrets/*.plaintext    # any accidentally-decrypted secrets files
secrets/*.dec          # sops -d > file.dec output convention
secrets/smoke.sops.yaml # smoke-test artifact from 8c-post-bootstrap.md §4; intentional — do not remove
decrypted/             # directory sometimes used to hold decrypted output

# Python (Phase 1 remnants — fully removed in Phase 2)
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / pnpm
node_modules/
apps/*/node_modules/
apps/*/dist/

# Frontend artifacts
apps/web/.vite/
apps/web/playwright-report/
apps/web/test-results/
apps/web/tsconfig.tsbuildinfo

# Runtime artifacts
logs/
reports/
.messages_snapshot/
data/

# OS/editor noise
.DS_Store
