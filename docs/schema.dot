  "raw_bank_transactions" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>raw_bank_transactions</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="connection_id">connection_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="sync_run_id">sync_run_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="provider_tx_id">provider_tx_id - VARCHAR(255) - NOT NULL</td></tr><tr><td align="left" port="date">date - DATE - NOT NULL</td></tr><tr><td align="left" port="description">description - VARCHAR(128) - NOT NULL</td></tr><tr><td align="left" port="amount_kd">amount_kd - NUMERIC(10, 3) - NOT NULL</td></tr><tr><td align="left" port="raw_payload_hash">raw_payload_hash - VARCHAR(64)</td></tr><tr><td align="left" port="category_hint">category_hint - VARCHAR(64)</td></tr><tr><td align="left" port="merchant_hint">merchant_hint - VARCHAR(64)</td></tr><tr><td align="left" port="status">status - VARCHAR(32) - NOT NULL</td></tr><tr><td align="left" port="transaction_id">transaction_id - INTEGER - FK</td></tr><tr><td align="left" port="created_at">created_at - DATETIME - NOT NULL</td></tr></table>>];
