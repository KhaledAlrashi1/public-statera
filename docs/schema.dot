digraph schema {
  graph [rankdir=LR, splines=true, overlap=false, nodesep=0.45, ranksep=0.9];
  node [shape=plain, fontname="IBM Plex Mono"];
  edge [color="#6b7280", arrowsize=0.7, penwidth=1.1, fontname="IBM Plex Mono", fontsize=10];
  "account_action_tokens" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>account_action_tokens</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="purpose">purpose - VARCHAR(32) - NOT NULL</td></tr><tr><td align="left" port="token_hash">token_hash - VARCHAR(64) - NOT NULL</td></tr><tr><td align="left" port="payload_json">payload_json - TEXT</td></tr><tr><td align="left" port="expires_at">expires_at - DATETIME - NOT NULL</td></tr><tr><td align="left" port="used_at">used_at - DATETIME</td></tr><tr><td align="left" port="created_at">created_at - DATETIME - NOT NULL</td></tr></table>>];
  "bank_connections" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>bank_connections</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="provider">provider - VARCHAR(64) - NOT NULL</td></tr><tr><td align="left" port="external_institution_id">external_institution_id - VARCHAR(255)</td></tr><tr><td align="left" port="account_number_masked">account_number_masked - VARCHAR(20)</td></tr><tr><td align="left" port="institution_name">institution_name - VARCHAR(255) - NOT NULL</td></tr><tr><td align="left" port="status">status - VARCHAR(32) - NOT NULL</td></tr><tr><td align="left" port="access_token">access_token - TEXT</td></tr><tr><td align="left" port="refresh_token">refresh_token - TEXT</td></tr><tr><td align="left" port="created_at">created_at - DATETIME - NOT NULL</td></tr><tr><td align="left" port="revoked_at">revoked_at - DATETIME</td></tr><tr><td align="left" port="last_synced_at">last_synced_at - DATETIME</td></tr></table>>];
  "bank_consents" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>bank_consents</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="connection_id">connection_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="scopes">scopes - TEXT - NOT NULL</td></tr><tr><td align="left" port="purpose_of_use">purpose_of_use - VARCHAR(512) - NOT NULL</td></tr><tr><td align="left" port="consent_reference">consent_reference - VARCHAR(128)</td></tr><tr><td align="left" port="data_recipient_name">data_recipient_name - VARCHAR(255) - NOT NULL</td></tr><tr><td align="left" port="scope_description">scope_description - TEXT - NOT NULL</td></tr><tr><td align="left" port="ip_address_granted">ip_address_granted - VARCHAR(64)</td></tr><tr><td align="left" port="user_agent_granted">user_agent_granted - VARCHAR(255)</td></tr><tr><td align="left" port="granted_at">granted_at - DATETIME - NOT NULL</td></tr><tr><td align="left" port="expires_at">expires_at - DATETIME</td></tr><tr><td align="left" port="revoked_at">revoked_at - DATETIME</td></tr><tr><td align="left" port="status">status - VARCHAR(32) - NOT NULL</td></tr></table>>];
  "bank_sync_runs" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>bank_sync_runs</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="connection_id">connection_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="status">status - VARCHAR(32) - NOT NULL</td></tr><tr><td align="left" port="provider_cursor">provider_cursor - VARCHAR(255)</td></tr><tr><td align="left" port="staged_count">staged_count - INTEGER - NOT NULL</td></tr><tr><td align="left" port="committed_count">committed_count - INTEGER</td></tr><tr><td align="left" port="created_at">created_at - DATETIME - NOT NULL</td></tr><tr><td align="left" port="committed_at">committed_at - DATETIME</td></tr><tr><td align="left" port="abandoned_at">abandoned_at - DATETIME</td></tr></table>>];
  "budgets" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>budgets</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="month">month - VARCHAR(7) - NOT NULL</td></tr><tr><td align="left" port="category_id">category_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="amount_kd">amount_kd - NUMERIC(10, 3) - NOT NULL</td></tr><tr><td align="left" port="updated_at">updated_at - DATETIME</td></tr></table>>];
  "categories" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>categories</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK</td></tr><tr><td align="left" port="name">name - VARCHAR(64) - NOT NULL</td></tr><tr><td align="left" port="is_income">is_income - BOOLEAN</td></tr><tr><td align="left" port="is_archived">is_archived - BOOLEAN - NOT NULL</td></tr><tr><td align="left" port="archived_at">archived_at - DATETIME</td></tr></table>>];
  "dashboard_snapshots" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>dashboard_snapshots</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="months_count">months_count - INTEGER - NOT NULL</td></tr><tr><td align="left" port="window_end_month">window_end_month - VARCHAR(7) - NOT NULL</td></tr><tr><td align="left" port="months_json">months_json - TEXT - NOT NULL</td></tr><tr><td align="left" port="monthly_json">monthly_json - TEXT - NOT NULL</td></tr><tr><td align="left" port="expense_by_category_json">expense_by_category_json - TEXT - NOT NULL</td></tr><tr><td align="left" port="computed_at">computed_at - DATETIME - NOT NULL</td></tr></table>>];
  "data_access_logs" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>data_access_logs</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="connection_id">connection_id - INTEGER - FK</td></tr><tr><td align="left" port="consent_id">consent_id - INTEGER - FK</td></tr><tr><td align="left" port="action">action - VARCHAR(64) - NOT NULL</td></tr><tr><td align="left" port="records_accessed">records_accessed - INTEGER - NOT NULL</td></tr><tr><td align="left" port="date_range_start">date_range_start - DATE</td></tr><tr><td align="left" port="date_range_end">date_range_end - DATE</td></tr><tr><td align="left" port="ip_address">ip_address - VARCHAR(64)</td></tr><tr><td align="left" port="created_at">created_at - DATETIME - NOT NULL</td></tr></table>>];
  "debt_accounts" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>debt_accounts</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="name">name - VARCHAR(128) - NOT NULL</td></tr><tr><td align="left" port="debt_type">debt_type - VARCHAR(32) - NOT NULL</td></tr><tr><td align="left" port="balance_kd">balance_kd - NUMERIC(12, 3) - NOT NULL</td></tr><tr><td align="left" port="apr_pct">apr_pct - NUMERIC(6, 3)</td></tr><tr><td align="left" port="minimum_payment_kd">minimum_payment_kd - NUMERIC(10, 3) - NOT NULL</td></tr><tr><td align="left" port="due_day">due_day - INTEGER</td></tr><tr><td align="left" port="is_active">is_active - BOOLEAN - NOT NULL</td></tr><tr><td align="left" port="notes">notes - VARCHAR(255)</td></tr><tr><td align="left" port="created_at">created_at - DATETIME - NOT NULL</td></tr><tr><td align="left" port="updated_at">updated_at - DATETIME - NOT NULL</td></tr></table>>];
  "ingested_messages" [label=<<table border='0' cellborder='1' cellspacing='0'><tr><td bgcolor="#1f2937" align="left"><font color="white"><b>ingested_messages</b></font></td></tr><tr><td align="left" port="id">id - INTEGER - PK</td></tr><tr><td align="left" port="user_id">user_id - INTEGER - FK NOT NULL</td></tr><tr><td align="left" port="sender">sender - VARCHAR(64) - NOT NULL</td></tr><tr><td align="left" port="msg_guid">msg_guid - VARCHAR(128)</td></tr><tr><td align="left" port="msg_rowid">msg_rowid - INTEGER</td></tr><tr><td align="left" port="text_hash">text_hash - VARCHAR(64)</td></tr><tr><td align="left" port="raw_text">raw_text - TEXT</td></tr><tr><td align="left" port="uts">uts - INTEGER</td></tr><tr><td align="left" port="is_expense">is_expense - BOOLEAN</td></tr></table>>];
