# Version control — never needed in the image
.git
.gitignore

# Environment / secrets — secrets must not be baked into the image
.env
.env.*
!.env.example

# Installed packages — reinstalled fresh in the deps stage
node_modules/
apps/*/node_modules/

# Frontend — dist is never needed (api ignores it; web
# image rebuilds it from source). Other apps/web files
# (src/, public/, index.html, *.config.*, tsconfig*.json)
# are kept in build context because the web image's
# build stage needs them; the api Dockerfile doesn't COPY
# them, so their presence in api's build context is
# harmless.
apps/web/dist/

# Deployment and tooling — not part of application runtime
docker/
docker-compose*.yml
nginx/
deploy/
!deploy/Caddyfile
tools/

# CI/CD
.github/

# Runtime logs
logs/
