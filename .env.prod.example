# Production example for a Statera deployment.
# Replace every placeholder before use.

COMPOSE_PROJECT_NAME=personal_statera_prod

POSTGRES_DB=personal_statera_prod
POSTGRES_USER=finance
POSTGRES_PASSWORD=replace-with-a-strong-password

SECRET_KEY=replace-with-a-64-char-secret
ENCRYPTION_KEY=replace-with-a-64-char-hex-key
OPERATOR_API_TOKEN=replace-with-a-64-char-token

CORS_ORIGINS=https://statera.example.com
FRONTEND_BASE_URL=https://statera.example.com

# Change these if this production stack must coexist with another local/proxy stack.
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

CELERY_CONCURRENCY=2
PROXY_FIX_NUM_PROXIES=1
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

POSTMARK_API_KEY=
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM=Statera <no-reply@example.com>
MAIL_USE_TLS=true
