# Local development defaults for this workspace.
# Copy to .env for local use.

COMPOSE_PROJECT_NAME=personal_statera

POSTGRES_USER=finance
POSTGRES_PASSWORD=change-me
POSTGRES_DB=personal_statera
POSTGRES_HOST_PORT=5435
REDIS_HOST_PORT=6379

DATABASE_URL=postgresql://finance:change-me@localhost:5435/personal_statera
TEST_DATABASE_URL=postgresql://finance:change-me@localhost:5435/personal_statera_test

FLASK_HOST=127.0.0.1
FLASK_PORT=5004
APP_PORT=8004

FRONTEND_DEV_HOST=127.0.0.1
FRONTEND_DEV_PORT=3001
CORS_ORIGINS=http://127.0.0.1:3001
FRONTEND_BASE_URL=http://127.0.0.1:3001

# Host Flask connects to the Docker Redis port below.
# Use a separate Redis DB index if this clone shares a host Redis with another app.
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
RATE_LIMIT_BACKEND=auto

PERSONAL_STATERA_DEV_MODE=true
# DINARTRACK_DEV_MODE=true  # Deprecated: use PERSONAL_STATERA_DEV_MODE instead
SECRET_KEY=
ENCRYPTION_KEY=
ENCRYPTION_KEY_PREVIOUS=
OPERATOR_API_TOKEN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

ENABLE_TEMPLATE_SUGGESTIONS=false
ENABLE_OPEN_BANKING=false
ENABLE_RECURRING_PATTERNS=true
REQUIRE_2FA_FOR_BANK_CONNECT=true
