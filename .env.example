# Local development defaults. Copy to .env and fill in secrets.

COMPOSE_PROJECT_NAME=public_statera

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=statera
MYSQL_USER=statera
MYSQL_PASSWORD=change-me
MYSQL_HOST_PORT=3306

# ── API (Node.js / Hono) ──────────────────────────────────────────────────────
DATABASE_URL=mysql://statera:change-me@mysql:3306/statera
API_PORT=3000
# 0.0.0.0 for Docker (port-forwarding requires binding all interfaces);
# override to 127.0.0.1 for native-only dev if you want stricter binding.
API_HOST=0.0.0.0

# ── Security ──────────────────────────────────────────────────────────────────
# SESSION_SECRET: 32+ random bytes, hex encoded. Used to sign session JWTs.
SESSION_SECRET=
# ENCRYPTION_KEY: 32 bytes (256 bits) as 64 hex chars. Used for AES-256-GCM field encryption.
ENCRYPTION_KEY=
ENCRYPTION_KEY_PREVIOUS=

# ── OAuth / OIDC ──────────────────────────────────────────────────────────────
# Default provider is Google. Set OAUTH_ISSUER_URL to swap to any OIDC-compliant issuer.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_ISSUER_URL=https://accounts.google.com
OAUTH_PROVIDER=google
OAUTH_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_HOST_PORT=6379

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_DEV_PORT=3002
CORS_ORIGINS=http://127.0.0.1:3002

# ── Integrations (optional) ───────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
POSTMARK_API_KEY=
MAIL_FROM_ADDRESS=noreply@example.com

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_OPEN_BANKING=false
ENABLE_TEMPLATE_SUGGESTIONS=false
ENABLE_RECURRING_PATTERNS=true

# ── Analytics cache ───────────────────────────────────────────────────────────
# Max seconds a single analytics SQL query is allowed to run (MySQL max_execution_time).
ANALYTICS_COMPUTE_TIMEOUT_SECONDS=10
# Seconds the analytics hard-fail circuit breaker stays open after a Redis failure.
ANALYTICS_CACHE_CIRCUIT_BREAKER_TIMEOUT_SECONDS=10
# When true, dashboard analytics return 503 on Redis outage instead of falling back to MySQL.
# Defaults true — silent degrade can cascade into MySQL DoS during long Redis outages.
ANALYTICS_CACHE_CIRCUIT_BREAKER_ENABLED=true
# Number of past months included in the dashboard snapshot window.
DASHBOARD_SNAPSHOT_MONTHS=24
# Rebuild snapshots for users who logged in (or registered) within this many days.
# Bare NULL last_login_at is excluded — that would rebuild every dormant user.
SNAPSHOT_REBUILD_WINDOW_DAYS=14
# Max concurrent users processed in a single rebuild-dashboard-snapshots run.
SNAPSHOT_REBUILD_CONCURRENCY=5

# ── Dev mode ──────────────────────────────────────────────────────────────────
STATERA_DEV_MODE=true

# ── Docker dev stack (optional) ───────────────────────────────────────────────
# Uncomment COMPOSE_FILE to make `docker compose up` automatically apply the
# dev overlay (source-mounted hot-reload api + worker + migrate service).
# Without this, use: docker compose -f docker-compose.yml -f docker-compose.dev.yml up
# COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
